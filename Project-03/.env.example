# ---- Server ----
PORT=4000

# ---- PostgreSQL ----
# Option A: full connection string (recommended)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/book_library

# Option B: individual parts (used only if DATABASE_URL is empty)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=book_library
